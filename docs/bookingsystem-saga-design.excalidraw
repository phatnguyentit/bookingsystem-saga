    {
      "id": "async_note",
      "type": "text",
      "x": 785,
      "y": 480,
      "width": 348.539794921875,
      "height": 56.25,
      "angle": 0,
      "strokeColor": "#374151",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
