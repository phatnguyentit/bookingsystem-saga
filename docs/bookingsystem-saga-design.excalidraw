      "index": "af",
      "roundness": null,
      "seed": 980930855,
      "version": 2,
      "versionNonce": 1249528871,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774770997293,
      "link": null,
      "locked": false,
      "text": "Use ASYNC when the caller does NOT need an\nimmediate response. Booking publishes an event\nand moves on — consumers react independently.",
      "fontSize": 15,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Use ASYNC when the caller does NOT need an\nimmediate response. Booking publishes an event\nand moves on — consumers react independently.",
      "autoResize": true,
      "lineHeight": 1.25
    },
